# Domain and host routing
# Production origins derived from these values:
# - Storefront: https://www.veloro.dk
# - Accounts/auth: https://accounts.veloro.dk
# - Admin: https://admin.veloro.dk
BASE_DOMAIN=veloro.dk
STOREFRONT_SUBDOMAIN=www
ADMIN_SUBDOMAIN=admin
AUTH_SUBDOMAIN=accounts

# Local development host overrides
LOCAL_STOREFRONT_ORIGIN=http://localhost:3000
LOCAL_ADMIN_ORIGIN=http://localhost:3001
LOCAL_AUTH_ORIGIN=http://localhost:3002

# Authentication
# Local: http://localhost:3002
# Production: https://accounts.veloro.dk
BETTER_AUTH_URL=http://localhost:3002
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_API_KEY=
BETTER_AUTH_API_URL=
BETTER_AUTH_KV_URL=

# Auth email delivery (Resend)
# Preview/production prefers Resend. If RESEND_API_KEY is not set yet, the
# existing BETTER_AUTH_API_KEY can temporarily deliver Better Auth templates.
# Auth flows fail loudly when neither provider is configured.
# For real inbox testing, use a verified Resend sender domain and a public
# HTTPS BETTER_AUTH_URL/tunnel. Localhost verification links can be accepted by
# mailbox providers and still filtered before they reach the inbox.
RESEND_API_KEY=
AUTH_EMAIL_FROM=SNN <accounts@veloro.dk>
AUTH_EMAIL_REPLY_TO=

# Google OAuth
# Authorized JavaScript origins:
# - http://localhost:3002
# - https://accounts.veloro.dk
# Authorized redirect URIs:
# - http://localhost:3002/api/auth/callback/google
# - https://accounts.veloro.dk/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign in
# Service ID / Return URLs:
# - http://localhost:3002/api/auth/callback/apple
# - https://accounts.veloro.dk/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Database
# Use Neon pooled URL for application runtime traffic.
DATABASE_URL=
# Use Neon direct URL for Drizzle migrations and schema tooling.
DATABASE_URL_UNPOOLED=
# Optional runtime pool tuning for pooled serverless connections.
DATABASE_POOL_MAX=
DATABASE_POOL_IDLE_TIMEOUT_MS=
DATABASE_POOL_CONNECTION_TIMEOUT_MS=
DATABASE_POOL_MAX_USES=

# Performance
# Enable structured timing logs on Vercel preview deployments only.
ENABLE_PERFORMANCE_TRACE=
# Disposable local/preview customer used by performance preflight and account flows.
PERF_CUSTOMER_EMAIL=
PERF_CUSTOMER_PASSWORD=

# Cloudflare
# Shared Cloudflare account credentials. Use these for account-scoped tooling
# when one token is allowed to manage the relevant Cloudflare features.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Images
# These override the shared Cloudflare credentials above when Images should use
# a dedicated, narrower token. CLOUDFLARE_IMAGES_DELIVERY_HASH is always Images-specific.
CLOUDFLARE_IMAGES_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
CLOUDFLARE_IMAGES_DELIVERY_HASH=
ENABLE_MEDIA_MANAGEMENT_IN_PRODUCTION=false

# Payments
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
# off|report|enforce. Production defaults to enforce when both Turnstile keys exist.
AUTH_TURNSTILE_MODE=

# Internal tooling
ENABLE_THEME_LAB_IN_PRODUCTION=false

# Optional read-only Vercel checks used by pnpm perf:edge.
# Keep these out of browser-exposed environments.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_STOREFRONT_PROJECT_ID=
VERCEL_ACCOUNTS_PROJECT_ID=
VERCEL_ADMIN_PROJECT_ID=
