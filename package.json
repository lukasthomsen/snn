{
  "name": "snn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "audit": "pnpm audit",
    "build": "turbo run build",
    "clean": "tsx scripts/maintenance/clean-generated.ts",
    "dev": "pnpm -r --parallel --filter @snn/storefront --filter @snn/admin --filter @snn/accounts run dev",
    "dev:storefront": "pnpm --filter @snn/storefront dev",
    "dev:admin": "pnpm --filter @snn/admin dev",
    "dev:accounts": "pnpm --filter @snn/accounts dev",
    "lint": "turbo run lint",
    "perf:all": "pnpm perf:lint && pnpm perf:lighthouse && pnpm perf:flows && pnpm perf:report",
    "perf:customer": "node tools/perf/setup-customer.cjs",
    "perf:edge": "node tools/perf/edge-audit.cjs",
    "perf:flows": "playwright test --config=playwright.performance.config.ts",
    "perf:install-browsers": "playwright install chromium",
    "perf:lint": "eslint tests/performance/storefront.spec.ts playwright.performance.config.ts \"tools/perf/**/*.{cjs,ts}\"",
    "perf:lighthouse": "pnpm perf:lighthouse:mobile && pnpm perf:lighthouse:desktop && pnpm perf:lighthouse:auth && pnpm perf:lighthouse:account",
    "perf:lighthouse:account": "node tools/perf/run-account-lighthouse.cjs",
    "perf:lighthouse:auth": "node tools/perf/run-auth-lighthouse.cjs",
    "perf:lighthouse:desktop": "lhci autorun --config=tools/perf/lighthouserc.desktop.cjs",
    "perf:lighthouse:mobile": "lhci autorun --config=tools/perf/lighthouserc.mobile.cjs",
    "perf:local": "node tools/perf/run-local-suite.cjs",
    "perf:preflight": "node tools/perf/preflight.cjs",
    "perf:report": "node tools/perf/write-step-one-report.cjs",
    "verify": "pnpm db:check:migrations && pnpm lint && pnpm typecheck && pnpm build",
    "media:ensure-variants": "tsx scripts/media/ensure-cloudflare-image-variants.ts",
    "typecheck": "turbo run typecheck",
    "db:check:migrations": "tsx scripts/maintenance/check-migrations.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:backfill:commerce": "tsx scripts/db/backfill-commerce-foundation.ts",
    "db:check:commerce": "tsx scripts/db/check-commerce-health.ts",
    "db:seed:commerce": "tsx scripts/db/seed-commerce-demo.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.13",
      "esbuild": "0.25.12",
      "samlify": "2.12.0",
      "kysely": "0.28.17",
      "minimatch@3.1.5>brace-expansion": "1.1.14",
      "minimatch@10.2.5>brace-expansion": "5.0.6",
      "tmp": "^0.2.5",
      "ws": "^8.20.1"
    }
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@snn/commerce": "workspace:*",
    "@snn/config": "workspace:*",
    "@snn/db": "workspace:*",
    "@snn/media": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "bufferutil": "^4.1.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "eslint": "^9.39.4",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "turbo": "2.9.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "ws": "^8.20.1"
  }
}
