{
  "name": "snn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@snn/storefront --filter=@snn/admin",
    "dev:storefront": "pnpm --filter @snn/storefront dev",
    "dev:admin": "pnpm --filter @snn/admin dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.13",
      "esbuild": "0.25.12"
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "bufferutil": "^4.1.0",
    "drizzle-kit": "0.31.10",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "turbo": "2.9.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "ws": "^8.20.0"
  }
}
