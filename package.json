{
  "name": "veloro",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@veloro/storefront --filter=@veloro/admin",
    "dev:storefront": "pnpm --filter @veloro/storefront dev",
    "dev:admin": "pnpm --filter @veloro/admin dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.13",
      "esbuild": "0.25.12"
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "0.31.10",
    "turbo": "2.9.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
